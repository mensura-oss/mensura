{
  "name": "mensura",
  "version": "0.0.0",
  "private": true,
  "description": "Open-source, self-hosted agentic development platform",
  "license": "AGPL-3.0-only",
  "packageManager": "pnpm@11.15.1+sha512.81350b07e53c9538a02f1f2303b4290fa2d7be04e56e2a970c4cc4b417dc761de196edabd49d55c7dc9580db81007c44143e4e3d7e462b3000d23c255122d065",
  "engines": {
    "node": ">=22",
    "pnpm": ">=11"
  },
  "scripts": {
    "build": "pnpm --recursive build",
    "check": "pnpm typecheck && pnpm test && pnpm build && pnpm --filter @mensura/studio check:native",
    "studio:build": "pnpm --filter @mensura/studio build:desktop",
    "studio:dev": "pnpm --filter @mensura/studio dev:desktop",
    "test": "pnpm --recursive test",
    "typecheck": "pnpm --recursive typecheck"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  }
}
